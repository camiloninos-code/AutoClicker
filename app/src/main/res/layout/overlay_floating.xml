<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/bg_overlay_panel"
    android:padding="8dp"
    android:elevation="8dp">

    <!-- Handle para arrastrar el overlay -->
    <View
        android:id="@+id/dragHandle"
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:background="#80FFFFFF"
        android:layout_marginBottom="6dp"
        android:layout_gravity="center_horizontal" />

    <!-- Contador de ciclos -->
    <TextView
        android:id="@+id/tvCycleCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0/∞"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"
        android:visibility="gone" />

    <!-- Botones Play/Pause y Stop en fila -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Play / Pause -->
        <ImageButton
            android:id="@+id/btnPlayPause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_media_play"
            android:background="@drawable/bg_overlay_button"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:contentDescription="Play / Pause" />

        <!-- Stop (oculto cuando IDLE) -->
        <ImageButton
            android:id="@+id/btnStop"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@drawable/bg_overlay_button_red"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:layout_marginStart="6dp"
            android:visibility="gone"
            android:contentDescription="Detener" />

    </LinearLayout>
</LinearLayout>
