<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#CC1A1A2E"
    android:padding="12dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Auto Clicker"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvWidgetState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="○ Detenido"
        android:textColor="#9E9E9E"
        android:textSize="11sp"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnWidgetStart"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="▶ Iniciar"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="#1565C0"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnWidgetStop"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="⏹ Parar"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="#C62828"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <Button
        android:id="@+id/btnWidgetOpen"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:text="Abrir app →"
        android:textColor="#90FFFFFF"
        android:textSize="11sp"
        android:background="@android:color/transparent"
        android:layout_marginTop="4dp" />

</LinearLayout>
