<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#33000000">

    <!-- Barra superior semi-transparente -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_gravity="top" android:orientation="horizontal"
        android:background="#CC212121" android:padding="12dp"
        android:gravity="center_vertical">

        <TextView android:id="@+id/tvRecorderCount"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⏺ 0 puntos grabados"
            android:textColor="#FFFFFF" android:textSize="16sp"/>

        <Button android:id="@+id/btnRecorderStop"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⏹ Parar"
            android:backgroundTint="#C62828"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

</FrameLayout>
